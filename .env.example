# .env.example — Copy to .env.local and fill in values.
# Never commit .env.local to git.

# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # SERVER ONLY — never expose to client

# ─── LLM Providers ───────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_key_here
SARVAM_API_URL=https://api.sarvam.ai/v1                # Optional: override endpoint
OPENAI_API_KEY=                                         # Optional fallback

# ─── Web Search / Grounding ──────────────────────────────────
TAVILY_API_KEY=tvly-your_key_here
SERPER_API_KEY=                                         # Optional

# ─── App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with__openssl_rand_-base64_32

# ─── Rate Limiting (Upstash Redis — optional but recommended) ─
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── Injected by Vercel automatically — do not set manually ──
# VERCEL_ENV=production|preview|development
# VERCEL_URL=your-deployment.vercel.app
